# --- External data sources (all free, no paid tiers, no keys required) ---
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
FIRST_EPSS_URL=https://api.first.org/data/v1/epss
CIRCL_CVE_URL=https://vulnerability.circl.lu/api/vulnerability
NVD_CVE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=

# --- Composite formula weights (see app/config.py for the full explanation) ---
CVSS_DEFAULT_WHEN_UNKNOWN=5.0
KEV_MULT_LISTED=1.5
KEV_MULT_NOT_LISTED=1.0
CRITICALITY_WEIGHT_LOW=1.0
CRITICALITY_WEIGHT_MEDIUM=1.5
CRITICALITY_WEIGHT_HIGH=2.0
CRITICALITY_WEIGHT_CRITICAL=3.0
REACHABILITY_RESTRICTED=1.0
REACHABILITY_INTERNAL=1.5
REACHABILITY_INTERNET_FACING=2.5
BLAST_RADIUS_MULT_MAX=3.0
BLAST_RADIUS_MULT_STUB=1.0
EPSS_HIGH_THRESHOLD=0.50
EPSS_MEDIUM_THRESHOLD=0.10
CVSS_HIGH_THRESHOLD=7.0
CVSS_MEDIUM_THRESHOLD=4.0

# --- Team 1 (discovery) - REST, not on shared Supabase ---
TEAM1_DISCOVERY_API=

# --- Team 2 (asset inventory) - shared Supabase table/column names ---
TEAM2_ASSETS_TABLE=assets
TEAM2_COL_CRITICALITY=criticality
TEAM2_COL_NETWORK_ZONE=network_zone
TEAM2_COL_ASSET_TYPE=asset_type
TEAM2_COL_FQDN=fqdn
TEAM2_COL_IP_ADDRESS=ip_address
TEAM2_COL_HOSTNAME=hostname
TEAM2_COL_ENVIRONMENT=environment
TEAM2_ASSET_INVENTORY_API=

# --- Team 4 (attack path / graph) - leave blank until their graph is queryable ---
TEAM4_GRAPH_API=

# --- Our own table ---
RISK_SCORES_TABLE=risk_scores

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
